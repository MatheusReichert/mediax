root = true

[*.cs]
# ── Encoding & whitespace ────────────────────────────────────────────────────
charset                  = utf-8-bom
end_of_line              = crlf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true

# ── .NET code style ──────────────────────────────────────────────────────────
dotnet_sort_system_directives_first                          = true
dotnet_style_qualification_for_field                        = false
dotnet_style_qualification_for_property                     = false
dotnet_style_predefined_type_for_locals_parameters_members  = true
dotnet_style_predefined_type_for_member_access              = true
dotnet_style_require_accessibility_modifiers                = for_non_interface_members
dotnet_style_readonly_field                                 = true:suggestion

# ── C# code style ────────────────────────────────────────────────────────────
csharp_style_var_for_built_in_types                  = false:suggestion
csharp_style_var_when_type_is_apparent               = true:suggestion
csharp_style_var_elsewhere                           = false:suggestion
csharp_prefer_braces                                 = when_multiline:suggestion
csharp_style_expression_bodied_methods               = when_on_single_line:suggestion
csharp_style_expression_bodied_properties            = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check= true:suggestion
csharp_style_throw_expression                        = true:suggestion
csharp_style_conditional_delegate_call               = true:suggestion
csharp_prefer_simple_using_statement                 = true:suggestion
csharp_style_namespace_declarations                  = file_scoped:suggestion

# ── Diagnostic severity overrides ────────────────────────────────────────────

# CA1062 — Validate arguments of public methods (source-gen delegates, not needed here)
dotnet_diagnostic.CA1062.severity = none

# CA1034 — Nested types should not be visible (common in generated code)
dotnet_diagnostic.CA1034.severity = suggestion

# CA1724 — Type names should not match namespaces (Mediax vs Mediator is fine)
dotnet_diagnostic.CA1724.severity = none

# CA2007 — Consider calling ConfigureAwait (library code targets async callers)
dotnet_diagnostic.CA2007.severity = none

# CA1848 — Use LoggerMessage delegates (valid but out of scope for behaviors)
dotnet_diagnostic.CA1848.severity = suggestion

# CA1305 / CA1310 — Specify IFormatProvider / StringComparison (low risk here)
dotnet_diagnostic.CA1305.severity = suggestion
dotnet_diagnostic.CA1310.severity = suggestion

# MA0004 — Use ConfigureAwait (same as CA2007)
dotnet_diagnostic.MA0004.severity = none

# MA0016 — Prefer returning collection abstraction (ValueTask pattern breaks this)
dotnet_diagnostic.MA0016.severity = none

# MA0051 — Method too long (generated code & behaviors are intentionally verbose)
dotnet_diagnostic.MA0051.severity = suggestion

# MA0048 — File name must match type name (generated .g.cs files break this)
dotnet_diagnostic.MA0048.severity = none

# ── Test projects ─────────────────────────────────────────────────────────────
[tests/**/*.cs]
# xUnit-specific: do not require public access modifiers on test classes
dotnet_diagnostic.CA1515.severity = none
# Allow magic strings in test display names
dotnet_diagnostic.CA1861.severity = none

# ── Benchmark project ─────────────────────────────────────────────────────────
[benchmarks/**/*.cs]
dotnet_diagnostic.CA1822.severity = none   # Members can be static (BDN requires instance methods)
dotnet_diagnostic.MA0011.severity = none   # IFormatProvider on ToString
